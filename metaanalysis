+     seTE = subset_data$se,
+     studlab = subset_data$study,
+     sm = "SMD"
+   )
+   cat("\n========== ", gene_name, " (CNA: Diploid vs Amplification) ==========\n")
+   print(summary(result))
+   return(result)
+ }
