> # ============================================
> # STEP 3 - Loader function for CNA files
> # (handles METABRIC microarray vs FH RNA-seq
> # log2 transformation differences automatically)
> # ============================================
> 
> load_cna_file <- function(filepath, gene_name, dataset_label) {
+   
+   data <- read_tsv(filepath, show_col_types = FALSE)
+   
+   atm_col  <- names(data)[grepl("^ATM:", names(data))][1]
+   gene_col <- names(data)[grepl(paste0("^", gene_name, ":"), names(data))][1]
+   
+   data <- data %>%
+     rename(ATM_CNA = !!atm_col, gene_raw = !!gene_col) %>%
+     filter(!is.na(ATM_CNA), !is.na(gene_raw))
+   
+   # METABRIC microarray values are already log2 - don't re-transform
+   # FH RNA-seq RSEM values are raw - need log2(value+1)
+   if (dataset_label == "FH") {
+     data <- data %>% mutate(gene_log2 = log2(gene_raw + 1))
+   } else {
+     data <- data %>% mutate(gene_log2 = gene_raw)
+   }
+   
+   data$ATM_CNA <- factor(data$ATM_CNA,
+                           levels = c("Deep Deletion", "Shallow Deletion",
+                                      "Diploid", "Gain", "Amplification"))
+   data$gene <- gene_name
+   data$dataset <- dataset_label
+   
+   return(data)
+ }
