> # Calculate effect sizes: Hypermethylated vs Hypomethylated
> calc_meth_effect <- function(data) {
+   hyper <- data %>% filter(meth_group == "Hypermethylated") %>% pull(gene_log2)
+   hypo  <- data %>% filter(meth_group == "Hypomethylated")  %>% pull(gene_log2)
+   cohen.d(hypo, hyper)
+ }
