> # ============================================
> # STEP 11 - Methylation files
> # NOTE: METABRIC = RRBS platform, FH = HM450 platform
> # Need k-means classification into Hyper/Hypomethylated
> # groups SEPARATELY per dataset before Cohen's d
> # ============================================
> 
> load_meth_file <- function(filepath, gene_name, dataset_label) {
+   
+   data <- read_tsv(filepath, show_col_types = FALSE)
+   
+   atm_col  <- names(data)[grepl("^ATM:", names(data))][1]
+   gene_col <- names(data)[grepl(paste0("^", gene_name, ":"), names(data))][1]
+   
+   data <- data %>%
+     rename(ATM_meth = !!atm_col, gene_raw = !!gene_col) %>%
+     filter(!is.na(ATM_meth), !is.na(gene_raw))
+   
+   if (dataset_label == "FH") {
+     data <- data %>% mutate(gene_log2 = log2(gene_raw + 1))
+   } else {
+     data <- data %>% mutate(gene_log2 = gene_raw)
+   }
+   
+   # K-means classification into 2 methylation groups,
+   # done independently within this dataset
+   set.seed(123)
+   km <- kmeans(data$ATM_meth, centers = 2)
+   
+   high_cluster <- which.max(km$centers)
+   
+   data$meth_group <- ifelse(km$cluster == high_cluster,
+                              "Hypermethylated", "Hypomethylated")
+   
+   data$gene <- gene_name
+   data$dataset <- dataset_label
+   return(data)
+ }
